    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(rm *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(git checkout -- *)",
      "Bash(git clean *)",
      "Bash(sudo *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/hook_allow_mcp.js",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/protect-backups.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/protect-backups-git.sh"
          }
        ]
      },
      {
        "matcher": "mcp__xcode__.*",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/hook_allow_mcp.js",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "sandbox": {
    "network": {},
    "additionalWritePaths": [
      "/Users/niyaro/Library/Developer/Xcode/DerivedData",
      "/Users/niyaro/Library/Caches/org.swift.swiftpm",
      "/Users/niyaro/Library/Developer/CoreSimulator",
      "/tmp/claude-501"
    ]
  },
  "plansDirectory": "./docs/plans"
}
